{
  "extends": [
    "@tsconfig/recommended/tsconfig.json",
    "@vue/tsconfig/tsconfig.json"
  ],
  "compilerOptions": {
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "lib": ["esnext", "dom", "dom.iterable"],
    "module": "esnext",
    "paths": { "#build/*": ["./node_modules/.veehance/*"] },
    "resolveJsonModule": true,
    "types": ["vite/client"]
  },
  "include": ["src/**/*.ts", "src/**/*.vue"],
  "exclude": []
}
