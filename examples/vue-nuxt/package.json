{
  "name": "@example/vue-nuxt",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "prepare": "[ ! -d .nuxt ] && nuxt prepare || true",
    "start": "node .output/server/index.mjs",
    "dev": "dotenv-run -- nuxt dev",
    "build": "nuxt build",
    "typecheck": "nuxt typecheck --noEmit",
    "clean": "git clean -xdf .nuxt .output .turbo node_modules"
  },
  "dependencies": {
    "@iconify/utils": "^3.1.1",
    "@iconify/vue": "^5.0.0",
    "@iconify-json/lucide": "^1.2.105",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/image": "^2.0.0",
    "@nuxtjs/color-mode": "^4.0.0",
    "@unhead/vue": "^3.1.0",
    "@veehance/core": "workspace:*",
    "@veehance/vue": "workspace:*",
    "@vueuse/core": "^14.2.1",
    "defu": "^6.1.7",
    "reka-ui": "^2.9.6",
    "scule": "^1.3.0",
    "tailwind-variants": "^3.2.2",
    "vue": "^3.5.33",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@nuxt/devtools": "^4.0.0-alpha.4",
    "@vue/devtools-core": "^8.1.1",
    "@vue/devtools-kit": "^8.1.1"
  }
}
