    "@unpic/svelte": "^1.0.1",
    "@veehance/core": "workspace:*",
    "@veehance/svelte": "workspace:*",
    "bits-ui": "^2.18.0",
    "defu": "^6.1.7",
    "mode-watcher": "^1.1.0",
    "sv-router": "^0.16.0",
    "scule": "^1.3.0",
    "svelte": "^5.55.5",
    "tailwind-variants": "^3.2.2",
    "zod": "^4.4.1"
  }
