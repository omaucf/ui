{
  "name": "@example/svelte-router",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "prepare": "[ ! -d .router ] && sv-router || true",
    "start": "vite preview",
    "dev": "dotenv-run -- vite dev",
