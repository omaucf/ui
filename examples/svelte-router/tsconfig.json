{
  "extends": [
    "@tsconfig/recommended/tsconfig.json",
    "@tsconfig/node24/tsconfig.json",
    "@tsconfig/svelte/tsconfig.json",
    "./.router/tsconfig.json"
  ],
  "compilerOptions": {
    "lib": ["esnext", "dom", "dom.iterable"],
    "module": "esnext",
    "paths": { "#build/*": ["./node_modules/.veehance/*"] },
    "resolveJsonModule": true,
    "types": ["node", "svelte", "vite/client"]
  },
  "include": ["src/**/*.ts", "src/**/*.svelte"],
  "exclude": []
}
