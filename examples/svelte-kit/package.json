{
  "name": "@example/svelte-kit",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "prepare": "[ ! -d .svelte-kit ] && svelte-kit sync || true",
    "start": "vite preview",
    "dev": "dotenv-run -- vite dev",
    "build": "vite build",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "clean": "git clean -xdf .output .svelte-kit .turbo generated node_modules"
  },
  "dependencies": {
    "@iconify/svelte": "^5.2.1",
    "@iconify/utils": "^3.1.1",
    "@iconify-json/lucide": "^1.2.105",
    "@unhead/svelte": "^3.1.0",
    "@unpic/svelte": "^1.0.1",
    "@veehance/core": "workspace:*",
    "@veehance/svelte": "workspace:*",
    "bits-ui": "^2.18.0",
    "defu": "^6.1.7",
    "mode-watcher": "^1.1.0",
    "scule": "^1.3.0",
    "svelte": "^5.55.5",
    "tailwind-variants": "^3.2.2",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^7.0.1"
  }
}
