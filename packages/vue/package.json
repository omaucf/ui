{
  "name": "@veehance/vue",
  "version": "0.0.0",
  "type": "module",
  "author": "@omaucf <omaucf@pm.me>",
  "license": "MIT",
  "homepage": "https://github.com/omaucf/ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omaucf/ui.git",
    "directory": "packages/vue"
  },
  "bugs": {
    "url": "https://github.com/omaucf/ui/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "imports": {
    "#build/app.config": "./.nuxt/app.config.js",
    "#build/theme/*": "./.nuxt/ui/*.ts",
    "#build/ui/*": "./.nuxt/ui/*.ts",
    "#build/ui.css*": "./.nuxt/ui.css"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "style": "./dist/index.css",
      "import": "./dist/index.js"
    },
    "./nuxt": "./dist/nuxt.js",
    "./template": "./dist/template.js",
    "./unplugin": "./dist/unplugin.js",
    "./vite": "./dist/vite.js",
    "./package.json": "./package.json"
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist/**/*.css",
    "dist/**/*.d.ts",
    "dist/**/*.js",
    "package.json"
  ],
  "scripts": {
    "prepare": "[ ! -d dist ] && run-s build || true",
    "dev": "tsdown --watch",
    "build": "tsdown",
    "test": "vitest run",
    "typecheck": "nuxt typecheck --noEmit",
    "clean": "git clean -xdf .nuxt .turbo dist coverage node_modules",
    "postinstall": "[ ! -d .nuxt ] && nuxt prepare || true"
  },
  "peerDependencies": {
    "@nuxt/kit": ">=4",
    "@nuxt/schema": ">=4",
    "@unhead/vue": ">=2",
    "defu": ">=6",
    "hookable": ">=6",
    "nuxt": ">=4",
    "vite": ">=8",
    "vue": ">=3"
  },
  "peerDependenciesMeta": {
    "@nuxt/kit": {
      "optional": true
    },
    "@unhead/vue": {
      "optional": true
    },
    "@vueuse/core": {
      "optional": true
    },
    "defu": {
      "optional": true
    },
    "hookable": {
      "optional": true
    },
    "nuxt": {
      "optional": true
    },
    "vite": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@veehance/ui": "workspace:*",
    "unplugin": "^3.0.0",
    "vite-plugin-webfont-dl": "^3.12.0"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.101",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/image": "^2.0.0",
    "@nuxtjs/color-mode": "^4.0.0",
    "@nuxtjs/mdc": "^0.21.1"
  }
}
