{
  "name": "@veehance/vue",
  "version": "0.0.0",
  "type": "module",
  "author": "@omaucf <omaucf@pm.me>",
  "license": "MIT",
  "homepage": "https://github.com/omaucf/ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omaucf/ui.git",
    "directory": "packages/vue"
  },
  "bugs": {
    "url": "https://github.com/omaucf/ui/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "imports": {
    "#build/app.config": "./generated/app.config.ts",
    "#build/theme/*": "./generated/theme/*.ts",
    "#build/ui.css": "./generated/ui.css"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "style": "./dist/index.css",
      "import": "./dist/index.js"
    },
    "./app": "./dist/lib/components/app/index.js",
    "./container": "./dist/lib/components/container/index.js",
    "./main": "./dist/lib/components/main/index.js",
    "./use-environment": "./dist/lib/composables/use-environment.js",
    "./use-forward-expose": "./dist/lib/composables/use-forward-expose.js",
    "./environment": "./dist/lib/providers/environment/index.js",
    "./utils": "./dist/lib/utils/index.js",
    "./utils/*": "./dist/lib/utils/*.js",
    "./define-nuxt-plugin": "./dist/base/composables/define-nuxt-plugin.js",
    "./use-app-config": "./dist/base/composables/use-app-config.js",
    "./use-color-mode": "./dist/base/composables/use-color-mode.js",
    "./use-color-mode/nuxt": "./dist/lib/composables/color-mode/use-color-mode.js",
    "./use-head": "./dist/base/composables/use-head.js",
    "./use-nuxt-app": "./dist/base/composables/use-nuxt-app.js",
    "./nuxt": "./dist/nuxt.js",
    "./template": "./dist/template.js",
    "./unplugin": "./dist/unplugin.js",
    "./vite": "./dist/vite.js",
    "./package.json": "./package.json",
    "./plugin": "./plugin.d.ts"
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist/**/*.css",
    "dist/**/*.d.ts",
    "dist/**/*.js",
    "generated/ui.css",
    "package.json",
    "plugin.d.ts"
  ],
  "scripts": {
    "prepare": "[ ! -d dist ] && run-s build || true",
    "dev": "tsdown --watch",
    "build": "tsdown",
    "test": "vitest run",
    "typecheck": "vue-tsc --noEmit",
    "clean": "git clean -xdf .turbo coverage dist generated node_modules"
  },
  "peerDependencies": {
    "@iconify/utils": ">=3",
    "@iconify/vue": ">=5",
    "@inertiajs/vue3": ">=3",
    "@nuxt/kit": ">=4",
    "@nuxt/schema": ">=4",
    "@tanstack/vue-router": ">=1",
    "@unhead/vue": ">=3",
    "@unpic/vue": ">=1",
    "@vueuse/core": ">=14",
    "defu": ">=6",
    "hookable": "^6.1.1",
    "nuxt": ">=4",
    "reka-ui": ">=2.9",
    "scule": ">=1",
    "tailwind-variants": ">=3",
    "vite": ">=8",
    "vue": ">=3",
    "vue-router": ">=5",
    "zod": ">=4"
  },
  "peerDependenciesMeta": {
    "@iconify/utils": {
      "optional": true
    },
    "@inertiajs/vue3": {
      "optional": true
    },
    "@iconify/vue": {
      "optional": true
    },
    "@nuxt/kit": {
      "optional": true
    },
    "@nuxt/schema": {
      "optional": true
    },
    "@tanstack/vue-router": {
      "optional": true
    },
    "@unhead/vue": {
      "optional": true
    },
    "@unpic/vue": {
      "optional": true
    },
    "@vueuse/core": {
      "optional": true
    },
    "defu": {
      "optional": true
    },
    "hookable": {
      "optional": true
    },
    "nuxt": {
      "optional": true
    },
    "reka-ui": {
      "optional": true
    },
    "scule": {
      "optional": true
    },
    "tailwind-variants": {
      "optional": true
    },
    "vite": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "vue-router": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/vite": "^4.2.4",
    "@veehance/core": "workspace:*",
    "knitwork": "^1.3.0",
    "magic-string": "^0.30.21",
    "mlly": "^1.8.2",
    "unplugin": "^3.0.0",
    "unplugin-auto-import": "^21.0.0",
    "vite-plugin-webfont-dl": "^3.12.0"
  },
  "devDependencies": {
    "unplugin-vue": "^7.2.0"
  }
}
