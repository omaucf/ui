{
  "name": "@veehance/ui",
  "version": "0.0.0",
  "type": "module",
  "author": "@omaucf <omaucf@pm.me>",
  "license": "MIT",
  "homepage": "https://github.com/omaucf/ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omaucf/ui.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/omaucf/ui/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "imports": {
    "#build/app.config": "./generated/app.config.ts",
    "#build/ui/*": "./generated/ui/*.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "style": "./dist/index.css",
      "import": "./dist/index.js"
    },
    "./iconset": "./dist/iconset/index.js",
    "./locale": "./dist/locale/index.js",
    "./preset": "./dist/preset/index.js",
    "./theme/content": "./dist/theme/content/index.js",
    "./theme/prose": "./dist/theme/prose/index.js",
    "./theme": "./dist/theme/index.js",
    "./constants": "./dist/lib/constants/index.js",
    "./functions": "./dist/lib/functions/index.js",
    "./helpers": "./dist/lib/helpers/index.js",
    "./schemas": "./dist/lib/schemas/index.js",
    "./types": "./dist/lib/types/index.js",
    "./utils": "./dist/lib/utils/index.js",
    "./colors": "./dist/lib/colors.js",
    "./defaults": "./dist/lib/defaults.js",
    "./config": "./dist/config.js",
    "./template": "./dist/template.js",
    "./package.json": "./package.json"
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist/**/*.css",
    "dist/**/*.d.ts",
    "dist/**/*.js",
    "package.json"
  ],
  "scripts": {
    "prepare": "[ ! -d dist ] && run-s build || true",
    "dev": "tsdown --watch",
    "build": "tsdown",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "git clean -xdf .turbo dist coverage generated node_modules"
  },
  "peerDependencies": {
    "@iconify/utils": ">=3",
    "defu": ">=6",
    "radash": ">=12",
    "scule": ">=1.3",
    "tailwind-variants": ">=3",
    "zod": ">=4"
  },
  "peerDependenciesMeta": {
    "@iconify/utils": {
      "optional": true
    },
    "defu": {
      "optional": true
    },
    "radash": {
      "optional": true
    },
    "scule": {
      "optional": true
    },
    "tailwind-variants": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "dependencies": {
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.101",
    "@iconify-json/vscode-icons": "^1.2.45"
  }
}
